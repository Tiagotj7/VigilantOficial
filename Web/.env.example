# URL e chave pública do projeto em Supabase Dashboard > Settings > API.
# Nunca use a service_role no navegador.
#NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
#NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_OU_PUBLISHABLE

# URL pública da API Nest. Em desenvolvimento, mantenha localhost.
#NEXT_PUBLIC_API_URL=http://localhost:3001
