# Runtime: conexão pooled do Supabase (porta 6543, com pgbouncer=true).
DATABASE_URL="postgresql://postgres.SEUS_PROJECT_REF:SUA_SENHA@aws-0-SUA_REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Somente Prisma CLI (migrate/introspect): conexão direta na porta 5432.
DIRECT_URL="postgresql://postgres:SUA_SENHA@db.SEUS_PROJECT_REF.supabase.co:5432/postgres"

# Domínios do front separados por vírgula. Inclua o domínio da Vercel em produção.
CORS_ORIGINS=http://localhost:3000

# Necessária para validar os access tokens enviados pelo front. A URL JWKS é
# derivada automaticamente; só defina SUPABASE_JWKS_URL se precisar sobrescrevê-la.
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
#SUPABASE_JWKS_URL=https://SEU_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
